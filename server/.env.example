# Copy this file to `.env` and fill in the values.

# Your OpenAI API key (get one at https://platform.openai.com/api-keys).
OPENAI_API_KEY=sk-...

# Base URL of your Base44 B2B dashboard app (the "control plane").
# The backend calls <BASE44_URL>/api/config and <BASE44_URL>/api/analytics.
# Leave blank to run fully local with built-in defaults.
BASE44_URL=https://your-navinate-app.base44.app

# Port the backend listens on. ngrok points at this.
PORT=3000

# Model. gpt-4o is fast and supports tool calling; swap to gpt-4o-mini for cheaper demos.
MODEL=gpt-4o
