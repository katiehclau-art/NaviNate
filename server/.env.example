# Copy this file to `.env` and fill in the values.

# Your OpenAI API key (get one at https://platform.openai.com/api-keys).
OPENAI_API_KEY=sk-...

# Base URL of your Base44 B2B dashboard app (the "control plane"). Base44 serves
# deployed functions under /functions/<name>. The backend calls
#   <BASE44_URL>/functions/config?clientId=<id>  ->
#     { brand_color, system_prompt, aggressiveness, company_website_url }
# and posts analytics to <BASE44_URL>/functions/analytics. The scraper reads
# company_website_url from the same config endpoint to know which site to crawl.
# Leave blank to run fully local with built-in defaults.
BASE44_URL=https://your-navinate-app.base44.app

# Port the backend listens on. ngrok points at this.
PORT=3000

# Model. gpt-4o is fast and supports tool calling; swap to gpt-4o-mini for cheaper demos.
MODEL=gpt-4o
