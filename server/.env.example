# Copy this file to `.env` and fill in the values.

# Your OpenAI API key (get one at https://platform.openai.com/api-keys).
OPENAI_API_KEY=sk-...

# Base URL of your Base44 B2B dashboard app (the "control plane"). Base44 serves
# deployed functions under /functions/<name>. The backend calls
#   <BASE44_URL>/functions/config?clientId=<id>  ->
#     { brand_color, system_prompt, aggressiveness, company_website_url }
# and posts analytics to <BASE44_URL>/functions/analytics. The scraper reads
# company_website_url from the same config endpoint to know which site to crawl.
# Leave blank to run fully local with built-in defaults.
BASE44_URL=https://your-navinate-app.base44.app

# Port the backend listens on. ngrok points at this.
PORT=3000

# Model. gpt-4o is fast and supports tool calling; swap to gpt-4o-mini for cheaper demos.
MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Voice (ElevenLabs). Leave ELEVENLABS_API_KEY blank to run NaviNate text-only —
# the widget then hides the mic button entirely instead of offering a dead one.
# ---------------------------------------------------------------------------

# Get one at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional: pin an existing agent (agent_...) built in the ElevenLabs dashboard.
# Leave blank and the backend provisions one agent per client automatically from
# their Base44 persona, wiring up the navigate_site / read_page / undo_last_action
# client tools. Provisioned ids are cached in server/voice-agents.json.
ELEVENLABS_AGENT_ID=

# Optional: pin a voice. LEAVE BLANK and the backend picks one your account can
# actually use (it lists your voices and prefers Sarah/Jessica/Bella/...).
# Careful pinning an id you found online: most famous voice ids (Rachel, etc.)
# live in the shared Voice Library, and free plans get HTTP 402
# "Free users cannot use library voices via the API" when an agent tries to use
# one. Clients can also override per-tenant with `voice_id` in Base44.
ELEVENLABS_VOICE_ID=

# TTS model. Flash has the lowest time-to-first-audio, which is what makes the
# conversation feel real; eleven_turbo_v2_5 trades a little latency for range.
# NOTE: the _v2_5 models are multilingual. An English-locked agent only accepts
# the English-only variants, so the backend automatically uses eleven_flash_v2
# for the agent when ELEVENLABS_LANGUAGE is "en". Set a non-English language and
# the _v2_5 model is used as written.
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5

# Agent language (ISO code). "en" locks the agent to English.
ELEVENLABS_LANGUAGE=en

# The LLM driving the voice agent's dialogue (NaviNate's own page-driving brain
# stays on MODEL above). Smaller = snappier turn-taking.
ELEVENLABS_AGENT_LLM=gpt-4o-mini
